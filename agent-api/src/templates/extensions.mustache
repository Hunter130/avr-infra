; agent:{{agentId}}
[demo]
exten => {{extensionNumber}},1,NoOp(Agent {{agentId}} skill={{skill}})
 same => n,Set(TIMEOUT(absolute)=1200)
 same => n,Answer()
 same => n,Ringing()
 same => n,Wait(1)
  same => n,Set(UUID=${SHELL(uuidgen | tr -d '\n')})
  same => n,Set(AGENT_ID={{agentId}})
  same => n,Set(CALL_START=${EPOCH})
  same => n,Set(CHANNEL(hangup_handler_push)=billing-handler,s,1)
  same => n,Set(PEER_CHAN=${IF($["${CHANNEL: -2}"="\;1"]?${CHANNEL:0:-2}\;2:)})
  same => n,Set(CUSTOMER_NUMBER=${IF($["${PEER_CHAN}"=""]?${CUSTOMER_NUMBER}:${IMPORT(${PEER_CHAN},CUSTOMER_NUMBER)})})
  same => n,Set(CALL_DIRECTION=${IF($["${PEER_CHAN}"=""]?${CALL_DIRECTION}:${IMPORT(${PEER_CHAN},CALL_DIRECTION)})})
  same => n,Set(OUTBOUND_CALLERID=${IF($["${PEER_CHAN}"=""]?${OUTBOUND_CALLERID}:${IMPORT(${PEER_CHAN},OUTBOUND_CALLERID)})})
  same => n,Set(CALL_DIRECTION=${IF($["${CALL_DIRECTION}"=""]?inbound:${CALL_DIRECTION})})
  same => n,Set(CUSTOMER_NUMBER=${IF($["${CUSTOMER_NUMBER}"=""]?${CALLERID(num)}:${CUSTOMER_NUMBER})})
  same => n,Set(MAP_BODY={"uuid":"${UUID}","agentId":"{{agentId}}","direction":"${CALL_DIRECTION}","customerNumber":"${CUSTOMER_NUMBER}"})
  same => n,Set(CURLOPT(httpheader)=Content-Type: application/json)
  same => n,Set(MAP_RES=${CURL(http://avr-sts-gemini:6037/map-agent,${MAP_BODY})})
  same => n,Set(JSON_BODY={"uuid":"${UUID}","payload":{"from":"${CALLERID(num)}","to":"${EXTEN}"}})
  same => n,Set(JSON_RESPONSE=${CURL(http://avr-core:6001/call,${JSON_BODY})})
  same => n,Set(DENOISE(rx)=on)
  same => n,MixMonitor(${UUID}.wav)
  same => n,Dial(AudioSocket/avr-core:5001/${UUID})
  same => n,Hangup()
