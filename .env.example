GEMINI_API_KEY=
GEMINI_INSTRUCTIONS="Eres un experto en atención al cliente. Tu nombre es Litay. Debes responder SIEMPRE en español de manera muy amable, clara y concisa., tu objetivo es notificar sobre un uso indevido de la tarejta de credito de BANAMEX y pedir validacion para poder levantar un reporte  y bloquear la tarjeta."

# Opciones de Voz de Gemini:
# Masculinas: Puck, Charon, Fenrir
# Femeninas: Aoede, Kore
GEMINI_VOICE=Kore
# Configuración de Análisis Post-Llamada
N8N_WEBHOOK_URL=
# Configuración para llamadas sin respuesta (opcional)
N8N_UNANSWERED_WEBHOOK_URL=
# deeepseek , google
POST_CALL_ANALYSIS_PROVIDER= 
DEEPSEEK_API_KEY=
DEEPGRAM_API_KEY=
COST_GEMINI_PER_SEC=0.001
COST_DEEPGRAM_PER_SEC=0.0005
RECORDING_BASE_URL=http://localhost:6038/recordings
# Agent API
SUPABASE_URL=
SUPABASE_KEY=
API_KEY=
KNOWLEDGE_BASE_ENDPOINT_URL=

# Ajustes de VAD (Voice Activity Detection) e Interrupción de Gemini Live API
#
# GEMINI_VAD_START_SENSITIVITY: Sensibilidad para detectar el inicio del habla del usuario (barge-in).
# - START_SENSITIVITY_HIGH: Alta sensibilidad (interrumpe rápido, pero puede activarse con ruido/respiraciones).
# - START_SENSITIVITY_UNSPECIFIED: Sensibilidad balanceada por defecto.
# - START_SENSITIVITY_LOW: Baja sensibilidad (requiere que el usuario hable más fuerte o claro para interrumpir).
GEMINI_VAD_START_SENSITIVITY=START_SENSITIVITY_HIGH

# GEMINI_VAD_END_SENSITIVITY: Sensibilidad para detectar cuándo el usuario ha terminado de hablar.
# - END_SENSITIVITY_HIGH: Alta sensibilidad (detecta el fin de habla rápidamente, ideal para respuestas rápidas).
# - END_SENSITIVITY_UNSPECIFIED: Sensibilidad balanceada por defecto.
# - END_SENSITIVITY_LOW: Baja sensibilidad (evita cortes si el usuario hace pausas largas, pero tarda más en responder).
GEMINI_VAD_END_SENSITIVITY=END_SENSITIVITY_UNSPECIFIED

# GEMINI_VAD_SILENCE_DURATION_MS: Duración del silencio (en milisegundos) requerido tras el fin
# del habla detectado para que la IA considere el turno terminado e inicie su respuesta.
# (Valores recomendados: entre 300 y 600 ms).
GEMINI_VAD_SILENCE_DURATION_MS=400

# GEMINI_VAD_PREFIX_PADDING_MS: Duración del búfer de audio previo (en milisegundos) que se añade
# antes de la detección de inicio de voz. Esto asegura que la primera sílaba o consonante del usuario
# no sea recortada al enviar el audio a Gemini. (Valor típico: 100 a 200 ms).
GEMINI_VAD_PREFIX_PADDING_MS=100